# ── Generated Content (stays local, never committed) ──────────────────────────

# Raw transcripts
outline*.md
transcript*.md

# Generated study guides, how-to guides, ebooks
master*.md
howto*.md
*-ebook.md
*-ebook.html
*-guide.md
*beginners-guide.md

# Entire courses/ folder if you create it
courses/

# HTML and PDF outputs (but keep webapp source)
*.html
!src/webapp/public/*.html
*.pdf

# Temp working directory used by scripts
.tmp/

# ── Node / JS tooling outputs ──────────────────────────────────────────────────
node_modules/
package-lock.json
ebooks/node_modules/
ebooks/package-lock.json
src/webapp/node_modules/
src/webapp/package-lock.json
.claude/skills/ebook-anything/node_modules/
.claude/skills/ebook-anything/package-lock.json

# Env files (never commit secrets)
.env
src/webapp/.env

# ── Claude personal config (keep skills, ignore everything else) ───────────────

# Personal credentials and OAuth tokens
.claude/.credentials.json
.claude/settings.json
.claude/settings.local.json

# Conversation history, project state, planning files
.claude/projects/
.claude/plans/
.claude/todos/
.claude/debug/
.claude/file-history/
.claude/plugins/

# All skills except ebook-anything
.claude/skills/*
!.claude/skills/ebook-anything

# ── OS & editor noise ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/
